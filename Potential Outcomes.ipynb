"""
LaLonde (1986) Replication & Extension
=======================================
원 논문: LaLonde, R.J. (1986). "Evaluating the Econometric Evaluations of 
         Training Programs with Experimental Data." AER 76(4), 604-620.

핵심 질문:
  NSW 직업훈련 프로그램(RCT)의 효과를 관찰 데이터 기반 추정량으로
  재현할 수 있는가?

데이터:
  - NSW experimental group (treated + control) → 실험적 벤치마크
  - CPS-1 comparison group                     → 관찰 데이터 (비교군)
  - PSID-1 comparison group                    → 관찰 데이터 (비교군)

변수:
  treatment  : 1 = NSW 훈련 참가
  age        : 나이
  education  : 교육 연수
  black      : 흑인 여부
  hispanic   : 히스패닉 여부
  married    : 기혼 여부
  nodegree   : 고졸 미만
  re74, re75 : 1974, 1975년 실질 소득 ($)
  re78       : 1978년 실질 소득 ($) ← 결과 변수
"""

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.gridspec as gridspec
from scipy import stats
from scipy.special import expit  # numerically stable sigmoid = 1/(1+exp(-x))

RNG = np.random.default_rng(2024)

plt.rcParams.update({
    "figure.dpi": 130,
    "figure.facecolor": "white",
    "axes.facecolor": "#f9f9f9",
    "axes.spines.top": False,
    "axes.spines.right": False,
    "axes.grid": True,
    "grid.alpha": 0.35,
    "axes.labelsize": 11,
    "axes.titlesize": 12,
    "axes.titleweight": "bold",
})


# ── 데이터 로드 ───────────────────────────────────────────────────────────────
# Dehejia & Wahba (1999)가 정리한 LaLonde 데이터 (NBER 공개)

_COLS = ["treatment","age","education","black","hispanic",
         "married","nodegree","re74","re75","re78"]

_URL_BASE = "https://raw.githubusercontent.com/matheusfacure/python-causality-handbook/master/causal-inference-for-the-brave-and-true/data"

nsw_treated = pd.read_csv(f"{_URL_BASE}/nsw_treated.csv")
nsw_control = pd.read_csv(f"{_URL_BASE}/nsw_control.csv")
cps_control = pd.read_csv(f"{_URL_BASE}/cps_controls.csv")
psid_control = pd.read_csv(f"{_URL_BASE}/psid_controls.csv")

# (1) 실험 데이터: NSW treated + NSW control
nsw = pd.concat([nsw_treated, nsw_control], ignore_index=True)

# (2) 관찰 데이터 A: NSW treated + CPS comparison
cps = pd.concat([nsw_treated, cps_control], ignore_index=True)

# (3) 관찰 데이터 B: NSW treated + PSID comparison
psid = pd.concat([nsw_treated, psid_control], ignore_index=True)

print("=" * 55)
print("  LaLonde 데이터셋 요약")
print("=" * 55)
for name, df_ in [("NSW (실험)", nsw), ("CPS (관찰)", cps), ("PSID (관찰)", psid)]:
    n1 = df_["treatment"].sum()
    n0 = (df_["treatment"] == 0).sum()
    print(f"  {name:12s}  N={len(df_):5d}  treated={n1:4d}  control={n0:4d}")
print("=" * 55)
